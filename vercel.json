{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": { "runtime": "python3.11" }
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "index.py" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "index.py" }
    ]
}