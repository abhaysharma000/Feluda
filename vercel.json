{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dashboard-react/dist"
            }
        },
        {
            "src": "app/main.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "app/main.py"
        },
        {
            "src": "/dashboard/(.*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "app/main.py"
        }
    ]
}