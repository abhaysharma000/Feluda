{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": { "runtime": "python3.11" }
        }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "index.py" },
        {
            "src": "/dashboard/(.*)",
            "headers": { "cache-control": "no-cache, no-store, must-revalidate" }
        },
        {
            "src": "/((?!dashboard/).*)",
            "dest": "index.py"
        }
    ]
}