{
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": { "runtime": "python3.11" }
        }
    ],
    "routes": [
        { "src": "/dashboard/assets/(.*)", "dest": "app/static/cyber-soc/assets/$1" },
        { "src": "/dashboard/(.*)", "dest": "app/static/cyber-soc/index.html" },
        { "src": "/api/(.*)", "dest": "index.py" },
        { "src": "/(.*)", "dest": "index.py" }
    ]
}