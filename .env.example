# OpenAI API Key — used for GPT-4o-mini semantic email analysis
OPENAI_API_KEY=your_openai_api_key_here

# VirusTotal API Key — for threat intelligence URL lookups
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing API Key
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_key_here

# MongoDB Atlas connection string (or local for dev)
MONGO_URI=mongodb://localhost:27017

# Backend port (default: 8001)
API_PORT=8001
